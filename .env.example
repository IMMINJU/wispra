# Copy this file to ".env" and fill in your key.
OPENAI_API_KEY=sk-your-key-here

# Optional overrides:
# The two output languages for the bidirectional pair (defaults: ko + en).
# Whatever is spoken is auto-detected; the session whose output differs
# translates. e.g. for Japanese↔English set LANG_A=ja and LANG_B=en.
# LANG_A=ko
# LANG_B=en
# PORT=3000
